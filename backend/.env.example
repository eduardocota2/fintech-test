APP_NAME=Bravo Credit API
APP_VERSION=0.1.0
API_PREFIX=/api/v1

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fintech-test
POSTGRES_PORT=5433

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/fintech-test

JWT_SECRET_KEY=change-me-in-env
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

WEBHOOK_TARGET_URL=http://localhost:8000/api/v1/webhooks/mock-receiver
WEBHOOK_TIMEOUT_SECONDS=5.0
WORKER_POLL_SECONDS=1.0
SSE_POLL_SECONDS=1.0
