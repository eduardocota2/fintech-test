APP_NAME=Fintech Backend
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
API_PORT=8000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fintech
POSTGRES_PORT=5434

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:${POSTGRES_PORT:-5434}/fintech

JWT_SECRET_KEY=change-me-in-env
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

WEBHOOK_TARGET_URL=http://localhost:8000/api/v1/webhooks/mock-receiver
WEBHOOK_TIMEOUT_SECONDS=5.0
WORKER_POLL_SECONDS=1.0
SSE_POLL_SECONDS=1.0
